# App
NODE_ENV=development
LOG_LEVEL=info

# LLM (OpenAI-compatible — set BASE_URL + API_KEY for your provider)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=opus
EMBED_MODEL=text-embedding-3-small

# Separate embedding endpoint — needed when LLM provider blocks OpenAI.
# Example: LLM via OpenRouter, embeddings direct to OpenAI:
#   EMBED_BASE_URL=https://api.openai.com/v1
#   EMBED_API_KEY=sk-...
EMBED_BASE_URL=
EMBED_API_KEY=

# Audio transcription (Whisper / OpenAI-compatible). Defaults to LLM_BASE_URL +
# LLM_API_KEY when unset. Used for Slack voice-message auto-transcription.
AUDIO_BASE_URL=
AUDIO_API_KEY=
AUDIO_MODEL=whisper-1

# Slack (M1.2 — set after registering Slack App)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Infra — matches docker-compose defaults
DATABASE_URL=postgres://superbot:superbot@localhost:5432/superbot
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=superbot
S3_SECRET_KEY=superbotsecret
S3_BUCKET=superbot

# Tool API keys (M4+)
TAVILY_API_KEY=
JINA_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
GITHUB_TOKEN=
E2B_API_KEY=
REPLICATE_API_TOKEN=
REPLICATE_MODEL=          # e.g. stability-ai/sdxl:39ed52f...

# Calendar (M8.3 — single-account refresh-token flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Browser / scraper / PDF (M9) — matches docker-compose
BROWSERLESS_URL=http://localhost:3000
BROWSERLESS_TOKEN=superbottoken
GOTENBERG_URL=http://localhost:3001

# Observability (M11)
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_PORT=9090

# Eval — use a different model to judge agent output (avoids self-grading bias).
# Defaults to LLM_MODEL if not set; falls back to LLM_BASE_URL + LLM_API_KEY.
JUDGE_MODEL=
JUDGE_BASE_URL=
JUDGE_API_KEY=

# Critic loop — post-response LLM review + retry on weak output.
CRITIC_ENABLED=true
CRITIC_MAX_RETRIES=2

# Eval + ops (M7)
MAINTAINER_USER_ID=        # Slack user id (U…) — receives weekly eval DM
AGENT_OPS_CHANNEL=         # Slack channel id (C…) — receives daily eval report + alerts

# Admin dashboard — comma-separated Slack user ids that can use /admin
ADMIN_USER_IDS=            # e.g. U123ABC,U456DEF

# db_query tool (M8.6) — separate analytics DB. Defaults to DATABASE_URL if unset.
ANALYTICS_DATABASE_URL=

# Outline (self-hosted wiki) — exposed via MCP server at mcp-servers/outline/server.ts
OUTLINE_BASE_URL=          # e.g. https://outline.spendbase.internal
OUTLINE_API_TOKEN=         # Bearer token from Outline → Settings → API Tokens

# Multica (managed-agents platform) — exposed via mcp-servers/multica/server.ts
MULTICA_BASE_URL=          # https://multica.ai (cloud) or self-hosted URL
MULTICA_API_TOKEN=         # PAT (mul_…) — Settings → Personal Access Tokens
MULTICA_WORKSPACE_SLUG=    # default workspace slug (preferred)
MULTICA_WORKSPACE_ID=      # fallback: workspace UUID if slug unknown
